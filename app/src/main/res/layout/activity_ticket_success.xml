<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Success Icon -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_check_circle"
            app:tint="@color/success"
            android:layout_marginTop="24dp"
            android:contentDescription="@string/booking_confirmed" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/booking_confirmed"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/show_qr_code"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <!-- QR Code -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginTop="24dp">

            <ImageView
                android:id="@+id/ivQrCode"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:padding="16dp"
                android:contentDescription="@string/cd_qr_code" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Ticket Code -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/ticket_code"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvTicketCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/primary"
            android:textSize="22sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            tools:text="MT-171234567-452" />

        <!-- Movie Info Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginTop="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvMovieTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"
                    tools:text="Avengers: Endgame" />

                <TextView
                    android:id="@+id/tvTheater"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:drawableStart="@drawable/ic_location"
                    android:drawablePadding="6dp"
                    tools:text="Galaxy Cinema Nguyễn Trãi" />

                <TextView
                    android:id="@+id/tvSeats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:drawableStart="@drawable/ic_seat"
                    android:drawablePadding="6dp"
                    tools:text="Seats: A1, A2" />

                <TextView
                    android:id="@+id/tvDateTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:drawableStart="@drawable/ic_clock"
                    android:drawablePadding="6dp"
                    tools:text="25/04/2024 at 19:00" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Reminder note -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Reminder set for 30 minutes before showtime"
            android:textColor="@color/info"
            android:textSize="13sp"
            android:drawableStart="@drawable/ic_notification"
            android:drawablePadding="6dp"
            android:drawableTint="@color/info" />

        <!-- Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewTickets"
            style="@style/Widget.App.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="@string/view_tickets"
            android:textSize="16sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackHome"
            style="@style/Widget.App.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="@string/back_to_home"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>